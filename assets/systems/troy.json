{
  // Troy — humanity's first colonised system. Yellow dwarf star, classic
  // tutorial sector. Nav layout below is taken from the WCU wiki
  // (https://www.wcnews.com/wcpedia/Troy) and scaled by × 10/3 to match
  // our engine's world units. We tried 10× first (Helen too distant),
  // then raw WCU (player swimming in the sun); 10/3 is the sweet spot
  // — Nav 8 ends up ~117 k from origin (sun reads as a comfortable
  // distant disc) and Helen ends up ~138 k from spawn (subtends a
  // chunky-but-not-overwhelming ~20° as a 50 km billboard).
  //
  // ⚠️ Coordinate convention note: the WCU wiki uses (X, Y_depth, Z_up)
  // — i.e. its Y is forward/back and its Z is vertical. Our engine is
  // (X, Y_up, Z_depth) where +Y is up and -Z is forward. The numbers
  // below are stored in OUR convention; in the table we list the wiki
  // ordering on the left and the engine-space coords (after Y↔Z swap)
  // on the right so it's easy to cross-check.
  //
  //   Nav | wiki (raw) Y_depth Z_up  | engine (×10/3) X Y_up Z_depth | What
  //   ----+-------------------------+------------------------------+-----------------------------------
  //    1  |  100000   40000    20000 |  100000   66667   133333    | Jump Point → Pyrenees    [stub]
  //    2  |  200000  -40000        0 |  200000 -133333        0    | Achilles Mining Base     ← sprite
  //    3  |  100000   40000   -40000 |  100000  133333  -133333    | Jump Point → Pender's    [stub]
  //    4  |  166667  -60000   -40000 |  166667 -133333  -200000    | Hector Mining Base       ← sprite
  //    5  |  150000  -30000   -20000 |  150000 -100000   -66667    | Jump Point → Regallis    [stub]
  //    6  |  166667  -20000    30000 |  166667  -66667   100000    | Helen Agricultural Planet ← sprite (billboard planet)
  //    7  |       0       0    45000 |       0       0   150000    | Jump Point → War         [stub]
  //    8  |   50000  -30000    10000 |   50000 -100000    33333    | (you are here / spawn)
  //
  // Jump points (1, 3, 5, 7) currently have no in-engine representation
  // — parked as future work. Once jump-point sprites + travel mechanics
  // land, we'll wire each Nav into the system loader as a typed entity.
  "name":        "Troy",
  "description": "Sol-like G-type system. Stable, well-mapped. Achilles and Hector mining bases work the inner belt; Helen feeds the colony from far orbit.",
  // Aesthetic re-skin (April 2026): swapped from the canonical Troy yellow-
  // dwarf + sparse-stars combo to a hot-blue O/B-type star drowning in a
  // violet nebula (sector_4774 skybox). Cool-on-cool sci-fi vibes; Sol-
  // analog look got boring. Lore-wise, treat as Troy seen through a deep
  // dust lane that didn't exist last patch. Revert by setting skybox_seed
  // back to "troy" and star.preset back to "yellow".
  "skybox_seed": "sector_4774",
  "star":        { "preset": "blue" },

  "asteroid_fields": [
    {
      // Inner belt wrapping the line between Achilles (Nav 2) and Hector
      // (Nav 4). After the wiki Y↔Z swap, both stations sit at Y_up =
      // -133333 (same vertical plane) and are separated mostly along Z
      // (Achilles z=0, Hector z=-200000), so the belt's center is the
      // midpoint of those two and the thickness lives in Z.
      "center":      [183333, -133333, -100000],
      "half_extent": [27000,    17000,  100000],
      "count":       320,
      "base_radius": 120,
      "seed":        2766780957
    }
  ],

  // Renderable points of interest — three sprites, no meshes. Mining
  // bases AND the planet ride the np-0kv billboard pipeline; one PNG
  // each, no per-instance art needed.
  "placed_sprites": [
    // Nav 2 — Achilles Mining Base. Confed-aligned, "north" of the belt
    // along the Z-depth axis. 3 km long — industrial complex scale
    // (2.5× the initial 1200 m; 6 km read as just slightly too big in
    // flight).
    {
      "sprite":        "sprites/mining_base",
      "position":      [200000, -133333, 0],
      "length_meters": 3000
    },
    // Nav 4 — Hector Mining Base. "South" along Z, same Y plane as
    // Achilles. Reuses the same sprite + lights sidecar as Achilles.
    {
      "sprite":        "sprites/mining_base",
      "position":      [166667, -133333, -200000],
      "length_meters": 3000
    },
    // Nav 6 — Helen Agricultural Planet. 10 km billboard sprite (504×512
    // pixel-art subject with atmospheric rim glow baked in). Sized
    // ~3.3× the mining bases — reads as a proper planet from medium
    // range without dwarfing every other landmark. Flat billboard, so
    // flying close-and-around is still a future feature (would need
    // the icosphere mesh path).
    {
      "sprite":        "sprites/helen_planet",
      "position":      [166667, -66667, 100000],
      "length_meters": 10000
    }
  ],

  // Multi-view ship billboards. The Tarsus uses all 32 generated views from
  // assets/ships/tarsus/atlas_manifest.json and chooses the nearest frame
  // at render time based on camera position.
  "placed_ship_sprites": [
    {
      "atlas":         "ships/tarsus/atlas_manifest",
      "position":      [50000, -100000, 33150],
      "length_meters": 100
    },
    // Talon parked 500u to starboard of the Tarsus so Mike can fly
    // between them and use F2 -> sprite light editor on either atlas.
    {
      "atlas":         "ships/talon/atlas_manifest",
      "position":      [50500, -100000, 33150],
      "length_meters": 80
    }
  ],
  // Navigation waypoints — what the in-game targeting system (press N
  // to cycle) sees. Includes the four jump points (which have no visual
  // representation yet) plus the renderable destinations. Position
  // values mirror placed_sprites entries above for stations + planet;
  // the duplication is intentional for now (sprites and nav have
  // different lifecycles — a wreck might be a sprite without a nav,
  // a long-range nav might be just a beacon with no sprite).
  "nav_points": [
    { "name": "Pyrenees Jump",      "kind": "jump",    "position": [100000,   66667,  133333] },
    { "name": "Achilles Mining",    "kind": "station", "position": [200000, -133333,       0] },
    { "name": "Pender's Star Jump", "kind": "jump",    "position": [100000,  133333, -133333] },
    { "name": "Hector Mining",      "kind": "station", "position": [166667, -133333, -200000] },
    { "name": "Regallis Jump",      "kind": "jump",    "position": [150000, -100000,  -66667] },
    { "name": "Helen Planet",       "kind": "planet",  "position": [166667,  -66667,  100000] },
    { "name": "Summoned Tarsus",    "kind": "ship",    "position": [ 50000, -100000,   33150] },
    { "name": "War Jump",           "kind": "jump",    "position": [     0,       0,  150000] }
  ],

  // Nav 8 from the WCU wiki — the canonical 'you arrive in Troy here'
  // spawn point. After the Y↔Z swap, spawn is at Y=-100000 (well below
  // midplane, roughly co-planar with the mining bases at Y=-133333)
  // and Z=33333 (slightly behind world origin in our -Z-forward
  // convention).
  "player_start": {
    "position": [50000, -100000, 33333]
  }
}
