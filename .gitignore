# ============================================================
# Project-specific (new_privateer / space_sim)
# ============================================================

# Build outputs
build/
build-*/
cmake-build-*/

# Generated shader headers (sokol-shdc output)
src/generated/
*.glsl.h

# Editor / IDE
.vscode/
.idea/
*.code-workspace
*.swp
compile_commands.json

# OS cruft
.DS_Store
._*

# Generated skyboxes (regenerated on demand by tools/gen_skybox.sh).
# Keep 'troy' so the binary has a default cubemap out of the box.
assets/skybox/*
!assets/skybox/troy/

# runtime logs
*.log

# Imported ship meshes from ../privateer_wcu. Derived from Origin/EA game
# assets — local use only, regenerate with tools/import_wcu_meshes.sh.
assets/meshes/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Python bytecode caches
__pycache__/
*.pyc

# In-game sprite atlas capture dirs (regeneratable via tools/tour_ship_sprite_atlas.sh)
assets/ships/*/sprites_ingame/

# Local AI sprite regeneration experiments (promote intentionally if useful)
assets/ships/*/regen_trials/

# Original Origin/EA WC sprite cache (do not redistribute)
assets/ships/*/wcnews_sprites/
